# Copy to .env for local runs (never commit .env). On Render, set these in the dashboard.
# Rotate any API key that was ever pasted into chat or committed to git.

PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
# 0 = live API; 1 = sandbox-api.paddle.com
PADDLE_SANDBOX=0

PADDLE_PRICE_SINGLE=
PADDLE_PRICE_DAY=
PADDLE_PRICE_MONTH=
PADDLE_PRICE_SIXMO=

FRONTEND_URL=http://localhost:5173
PUBLIC_CONTACT_EMAIL=

# Optional checkout address defaults (Israel)
# PADDLE_CHECKOUT_COUNTRY=IL
# PADDLE_CHECKOUT_POSTAL_CODE=6100001
