# =============================================================================
# Local development & payment testing
# =============================================================================
# 1. Copy this file to `.env` in the same folder as `web_app.py`:
#      copy .env.example .env
# 2. Fill in values (never commit `.env` — it is gitignored).
#
# Render / ephemeral disks: billing + guest trials live in SQLite (default `data/users.sqlite3`).
# Without a persistent disk, each deploy or instance reset clears entitlements. Set USER_DB_PATH to a
# mounted volume path if you need durable guest trial tracking across restarts.
# USER_DB_PATH=/var/data/users.sqlite3
# 3. Run: uvicorn web_app:app --reload --host 127.0.0.1 --port 8000
#
# Frontend (Vite) in translate-chat-frontend: use a `.env` with
#   VITE_API_BASE_URL=http://127.0.0.1:8000
#   VITE_PADDLE_CLIENT_TOKEN=<Paddle client token from Developer tools>
#   VITE_PADDLE_ENV=production
#
# Webhooks: Paddle cannot reach http://127.0.0.1. For full local tests, use
# ngrok (or similar), point Paddle Notifications to https://<tunnel>/billing/webhook,
# and set PADDLE_WEBHOOK_SECRET to that destination’s signing secret.
# =============================================================================

# --- Auth (required for signed-in checkout) ---
JWT_SECRET=

# --- AI / vision (required for translation jobs) ---
GEMINI_API_KEY=
GOOGLE_VISION_API_KEY=
# Full pipeline + Gemini/OCR detail logs (HTTP wait lines, CRAFT, debug paths). CLI: `python main.py -v`.
# Default (unset): stdout shows only high-level milestones — Starting up…, Pass 1…2…3…, Generating image…, Done.
# PIPELINE_VERBOSE=1
# HTTP read timeout (seconds) for Gemini generateContent. Matches pre–backend defaults:
# GEMINI_REQUEST_TIMEOUT_SEC=600 for all passes when GEMINI_PASS{n}_TIMEOUT_SEC are unset.
# GEMINI_REQUEST_TIMEOUT_SEC=600
# GEMINI_PASS1_TIMEOUT_SEC=
# GEMINI_PASS2_TIMEOUT_SEC=
# GEMINI_PASS3_TIMEOUT_SEC=
# GEMINI_PASS4_TIMEOUT_SEC=
#
# Gemini 2.5 Pro: thinkingConfig is not sent (historical behavior). This project targets Pro, not Flash.
# Gemini 2.5 Flash / Flash-Lite only: thinkingBudget via GEMINI_THINKING_BUDGET (default 0) or GEMINI_PASS{n}_THINKING_BUDGET.
# GEMINI_THINKING_BUDGET=0
#
# Default max output tokens 32768 (snappier). For huge threads / MAX_TOKENS on JSON, try 65536.
# GEMINI_MAX_OUTPUT_TOKENS=65536
#
# After each pipeline Gemini call, print one line: wall time, thinkingBudget cap, thoughts_tokens
# from the API (usage), finishReason, output size. Set to 0 to hide. If unset, follows PIPELINE_VERBOSE.
# GEMINI_PASS_SUMMARY=1
# TTY: single-line live progress (spinner bar + elapsed) during each Gemini HTTP call. If unset, follows PIPELINE_VERBOSE.
# GEMINI_WAIT_UI=1

# --- Paddle Billing ---
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
# Omit or 0 = live Paddle (api.paddle.com). Set 1 only if you use Paddle sandbox.
# PADDLE_SANDBOX=0

PADDLE_PRICE_SINGLE=
# Optional: one-time test price (≥ $0.70 USD in Paddle — their minimum charge)
PADDLE_PRICE_DEBUG=
PADDLE_PRICE_MONTH=
PADDLE_PRICE_SIXMO=
PADDLE_PRICE_YEAR=

# Checkout return URL: local Vite default is port 5173. Must be allowlisted in Paddle.
FRONTEND_URL=http://localhost:5173

# Subscription: max successful jobs per calendar month (default 7)
# BILLING_SUBSCRIPTION_RUNS_PER_MONTH=7

# Optional: enforce billing on POST /jobs (0 = off while testing)
# BILLING_ENFORCE=0
# REQUIRE_AUTH_FOR_JOBS=0

PUBLIC_CONTACT_EMAIL=

# --- CORS (production: set FRONTEND_URL or comma-separated CORS_ORIGINS; else allow *) ---
# Must match the browser origin exactly (https, apex vs www). After a custom domain change,
# update Render env — a bad value (e.g. a lone comma) can parse to zero origins and break all sites.
# CORS_ORIGINS=https://chatreconstruct.com,https://www.chatreconstruct.com,https://yourapp.netlify.app,http://localhost:5173

# --- Rate limits (per IP, in-memory). Set RATE_LIMIT_ENABLED=0 to disable. ---
# RATE_LIMIT_JOBS_PER_HOUR=30
# RATE_LIMIT_AUTH_PER_MIN=25
# RATE_LIMIT_BILLING_PER_MIN=60
# RATE_LIMIT_WEBHOOK_PER_MIN=120
# RATE_LIMIT_TEST_PER_HOUR=12

# --- Job intake ---
# MAX_JOB_FILES=30
# MAX_JOB_UPLOAD_MB=80

# --- Optional error monitoring ---
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0

# Optional checkout address defaults (Israel)
# PADDLE_CHECKOUT_COUNTRY=IL
# PADDLE_CHECKOUT_POSTAL_CODE=6100001
# PADDLE_CHECKOUT_REGION=
# PADDLE_CHECKOUT_CITY=
