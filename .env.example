# Copy to .env for local runs (never commit .env). On Render, set these in the dashboard.
# Rotate any API key that was ever pasted into chat or committed to git.

PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
# Omit or 0 = live Paddle (api.paddle.com). Set 1 only if you use Paddle sandbox.
# PADDLE_SANDBOX=0

PADDLE_PRICE_SINGLE=
# Optional: one-time test price (e.g. $0.10) — same as single (1 job credit)
PADDLE_PRICE_DEBUG=
PADDLE_PRICE_MONTH=
PADDLE_PRICE_SIXMO=
PADDLE_PRICE_YEAR=

# Subscription: max successful jobs per calendar month (~$2.50 COGS at ~$0.35/run → default 7)
# BILLING_SUBSCRIPTION_RUNS_PER_MONTH=7

FRONTEND_URL=http://localhost:5173
PUBLIC_CONTACT_EMAIL=

# Optional checkout address defaults (Israel)
# PADDLE_CHECKOUT_COUNTRY=IL
# PADDLE_CHECKOUT_POSTAL_CODE=6100001
